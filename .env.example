# AI API configuration
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://aihubmix.com/v1
APP_CODE=

MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# OCR & image hosting (my-bets image recognition)
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key
BAIDU_OCR_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
BAIDU_OCR_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic
IMGLOC_API_KEY=your-imgloc-api-key
IMGLOC_API_URL=https://imgloc.com/api/1/upload

# MySQL configuration
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/letoume?charset=utf8mb4
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=letoume
LOTTERY_SPLIT_TABLES_ENABLED=true

# FastAPI configuration
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Runtime environment
APP_ENV=dev

# SMTP (password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=LetouMe
AUTH_EMAIL_CODE_EXPIRE_MINUTES=10
AUTH_EMAIL_CODE_COOLDOWN_SECONDS=60

# OAuth placeholders
AUTH_OAUTH_BASE_URL=http://localhost:8000
AUTH_OAUTH_GOOGLE_CLIENT_ID=
AUTH_OAUTH_GOOGLE_CLIENT_SECRET=
AUTH_OAUTH_GOOGLE_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
AUTH_OAUTH_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
AUTH_OAUTH_GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
AUTH_OAUTH_GOOGLE_REDIRECT_URI=
AUTH_OAUTH_GITHUB_CLIENT_ID=
AUTH_OAUTH_GITHUB_CLIENT_SECRET=
AUTH_OAUTH_GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
AUTH_OAUTH_GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
AUTH_OAUTH_GITHUB_USERINFO_URL=https://api.github.com/user
AUTH_OAUTH_GITHUB_EMAILS_URL=https://api.github.com/user/emails
AUTH_OAUTH_GITHUB_REDIRECT_URI=
AUTH_OAUTH_STATE_TTL_SECONDS=600
