# OCR & image hosting (my-bets image recognition)
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key
BAIDU_OCR_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
BAIDU_OCR_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic

# MySQL configuration
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/letoume?charset=utf8mb4
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=letoume

# FastAPI configuration
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Runtime environment
APP_ENV=dev

# SMTP (password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=LetouMe
AUTH_EMAIL_CODE_EXPIRE_MINUTES=10
AUTH_EMAIL_CODE_COOLDOWN_SECONDS=60

AUTH_BOOTSTRAP_ADMIN_USERNAME=letoume
AUTH_BOOTSTRAP_ADMIN_PASSWORD=letoume123
